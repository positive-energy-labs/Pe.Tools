<?xml version="1.0" encoding="utf-8"?>
<configuration>
    <packageSources>
        <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
        <!-- Pe.Revit.Sdk prerelease feed: committed nupkgs so CI restores without machine-local
             paths. Swap for nuget.org once the beta publishes there (D6). -->
        <add key="pe-revit-sdk" value="eng/sdk-feed" />
    </packageSources>
</configuration>
