<Project>
    <PropertyGroup>
        <Configurations>Debug.R23;Debug.R24;Debug.R25;Debug.R26</Configurations>
        <Configurations
        >$(Configurations);Release.R23;Release.R24;Release.R25;Release.R26</Configurations>
    </PropertyGroup>

    <PropertyGroup Condition="'$(EnableRevitTestConfigurations)' == 'true'">
        <Configurations
        >$(Configurations);Debug.R23.Tests;Debug.R24.Tests;Debug.R25.Tests;Debug.R26.Tests</Configurations>
        <Configurations
        >$(Configurations);Release.R23.Tests;Release.R24.Tests;Release.R25.Tests;Release.R26.Tests</Configurations>
    </PropertyGroup>

    <PropertyGroup
        Condition="'$(MSBuildProjectName)' != 'Build' and '$(MSBuildProjectName)' != 'Installer'"
    >
        <Configuration Condition="'$(Configuration)' == ''">Debug.R25</Configuration>
        <_IsNoRevitConfig
            Condition="'$(RevitVersion)' == '' Or '$(RevitVersion)' == '-1'"
        >true</_IsNoRevitConfig>
        <RevitVersion Condition="'$(_IsNoRevitConfig)' == 'true'">2025</RevitVersion>
        <TargetFramework
            Condition="'$(_IsNoRevitConfig)' == 'true'"
        >net8.0-windows</TargetFramework>
    </PropertyGroup>

    <PropertyGroup
        Condition="'$(MSBuildProjectName)' != 'Build' and '$(MSBuildProjectName)' != 'Installer' and '$(Configuration)' != ''"
    >
        <IsRepackable>false</IsRepackable>
    </PropertyGroup>

    <PropertyGroup Condition="'$(Configuration)' != ''">
        <IntermediateOutputPath>obj\$(Configuration)\</IntermediateOutputPath>
    </PropertyGroup>

    <!-- I dont remember what this propgroup is for -->
    <PropertyGroup
        Condition="'$(Configuration)' != '' and $([System.String]::Copy('$(Configuration)').Contains('.R')) == 'True'"
    >
        <MSBuildProjectExtensionsPath>obj\$(Configuration)\</MSBuildProjectExtensionsPath>
    </PropertyGroup>

    <PropertyGroup
        Condition="'$(Configuration)' != '' and $([System.String]::Copy('$(Configuration)').Contains('.Tests')) == 'True'"
    >
        <BaseOutputPath>$(MSBuildThisFileDirectory).artifacts\tests\bin\</BaseOutputPath>
    </PropertyGroup>
</Project>
