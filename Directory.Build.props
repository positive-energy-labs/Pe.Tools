<Project>
    <PropertyGroup>
        <Configurations>Debug.R23;Debug.R24;Debug.R25;Debug.R26</Configurations>
        <Configurations>$(Configurations);Release.R23;Release.R24;Release.R25;Release.R26</Configurations>
        <DefaultItemExcludes>$(DefaultItemExcludes);obj\**</DefaultItemExcludes>
    </PropertyGroup>

    <PropertyGroup Condition="'$(Configuration)' != ''">
        <BaseIntermediateOutputPath>obj\$(Configuration)\</BaseIntermediateOutputPath>
        <IntermediateOutputPath>$(BaseIntermediateOutputPath)</IntermediateOutputPath>
    </PropertyGroup>

    <PropertyGroup Condition="'$(EnableRevitTestConfigurations)' == 'true'">
        <Configurations>$(Configurations);Debug.R23.Tests;Debug.R24.Tests;Debug.R25.Tests;Debug.R26.Tests</Configurations>
        <Configurations>$(Configurations);Release.R23.Tests;Release.R24.Tests;Release.R25.Tests;Release.R26.Tests</Configurations>
    </PropertyGroup>

    <PropertyGroup>
        <IsBuildOrInstallerProject Condition="'$(MSBuildProjectName)' == 'Build' or '$(MSBuildProjectName)' == 'Installer'">true</IsBuildOrInstallerProject>
        <IsBuildOrInstallerProject Condition="'$(IsBuildOrInstallerProject)' == ''">false</IsBuildOrInstallerProject>

        <IsSharedNeutralProject
                Condition="'$(IsSharedNeutralProject)' == '' and ($([System.String]::Copy('$(MSBuildProjectName)').StartsWith('Pe.Shared.')) == 'True' or '$(MSBuildProjectName)' == 'Toon')"
        >true</IsSharedNeutralProject>
        <IsSharedNeutralProject Condition="'$(IsSharedNeutralProject)' == ''">false</IsSharedNeutralProject>

        <IsOutOfProcNet8Project
                Condition="'$(IsOutOfProcNet8Project)' == '' and ('$(MSBuildProjectName)' == 'Pe.Host' or $([System.String]::Copy('$(MSBuildProjectName)').StartsWith('Pe.Dev.')) == 'True')"
        >true</IsOutOfProcNet8Project>
        <IsOutOfProcNet8Project Condition="'$(IsOutOfProcNet8Project)' == ''">false</IsOutOfProcNet8Project>

        <IsRevitTestProject Condition="'$(IsRevitTestProject)' == '' and '$(MSBuildProjectName)' == 'Pe.Revit.Tests'">true</IsRevitTestProject>
        <IsRevitTestProject Condition="'$(IsRevitTestProject)' == ''">false</IsRevitTestProject>

        <IsRevitProject
                Condition="'$(IsRevitProject)' == '' and ('$(MSBuildProjectName)' == 'Pe.App' or ($([System.String]::Copy('$(MSBuildProjectName)').StartsWith('Pe.Revit.')) == 'True' and '$(MSBuildProjectName)' != 'Pe.Revit.Tests'))"
        >true</IsRevitProject>
        <IsRevitProject Condition="'$(IsRevitProject)' == ''">false</IsRevitProject>
    </PropertyGroup>

    <PropertyGroup Condition="'$(IsBuildOrInstallerProject)' == 'true'">
        <DeployAddin>false</DeployAddin>
    </PropertyGroup>

    <PropertyGroup Condition="'$(IsBuildOrInstallerProject)' != 'true'">
        <Configuration Condition="'$(Configuration)' == ''">Debug.R25</Configuration>

        <_RevitConfigurationVersion Condition="'$(RevitVersion)' == '' or '$(RevitVersion)' == '-1'">$([System.Text.RegularExpressions.Regex]::Match('$(Configuration)', '.*\.R(\d{2}|\d{4})(?:\.|$)').Groups[1].Value)</_RevitConfigurationVersion>
        <RevitVersion Condition="('$(RevitVersion)' == '' or '$(RevitVersion)' == '-1') and '$(_RevitConfigurationVersion.Length)' == '4'">$(_RevitConfigurationVersion)</RevitVersion>
        <RevitVersion Condition="('$(RevitVersion)' == '' or '$(RevitVersion)' == '-1') and '$(_RevitConfigurationVersion.Length)' == '2'">20$(_RevitConfigurationVersion)</RevitVersion>
        <_IsNoRevitConfig Condition="'$(RevitVersion)' == '' or '$(RevitVersion)' == '-1'">true</_IsNoRevitConfig>
        <RevitVersion Condition="'$(_IsNoRevitConfig)' == 'true'">2025</RevitVersion>

        <TargetFramework Condition="'$(TargetFramework)' == '' and '$(IsSharedNeutralProject)' == 'true'">netstandard2.0</TargetFramework>
        <TargetFramework Condition="'$(TargetFramework)' == '' and ('$(IsOutOfProcNet8Project)' == 'true' or '$(IsRevitTestProject)' == 'true')">net8.0-windows</TargetFramework>
        <TargetFramework Condition="'$(TargetFramework)' == '' and '$(IsRevitProject)' == 'true' and ('$(RevitVersion)' == '2022' or '$(RevitVersion)' == '2023' or '$(RevitVersion)' == '2024')">net48</TargetFramework>
        <TargetFramework Condition="'$(TargetFramework)' == '' and '$(IsRevitProject)' == 'true' and ('$(RevitVersion)' == '2025' or '$(RevitVersion)' == '2026')">net8.0-windows</TargetFramework>
        <TargetFramework Condition="'$(TargetFramework)' == '' and '$(_IsNoRevitConfig)' == 'true'">net8.0-windows</TargetFramework>
    </PropertyGroup>

    <PropertyGroup Condition="'$(IsBuildOrInstallerProject)' != 'true' and '$(Configuration)' != ''">
        <IsRepackable>false</IsRepackable>
    </PropertyGroup>

    <PropertyGroup Condition="'$(Configuration)' != '' and $([System.String]::Copy('$(Configuration)').Contains('.R')) == 'True'">
        <MSBuildProjectExtensionsPath>$(BaseIntermediateOutputPath)</MSBuildProjectExtensionsPath>
    </PropertyGroup>

    <PropertyGroup Condition="'$(Configuration)' != '' and $([System.String]::Copy('$(Configuration)').Contains('.Tests')) == 'True'">
        <BaseOutputPath>$(MSBuildThisFileDirectory).artifacts\tests\bin\</BaseOutputPath>
    </PropertyGroup>

    <PropertyGroup
            Condition="'$(IsBuildOrInstallerProject)' != 'true' and '$(Configuration)' != '' and !$([System.String]::Copy('$(Configuration)').Contains('Release'))"
    >
        <AssemblyVersion>1.0.0.0</AssemblyVersion>
        <FileVersion>1.0.0.0</FileVersion>
        <InformationalVersion>dev</InformationalVersion>
    </PropertyGroup>
</Project>
