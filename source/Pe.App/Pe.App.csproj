<Project Sdk="Nice3point.Revit.Sdk/6.2.1">
    <PropertyGroup>
        <UseWPF>true</UseWPF>
        <DeployAddin Condition="'$(DeployAddin)' == ''">true</DeployAddin>
        <LaunchRevit Condition="'$(LaunchRevit)' == ''">true</LaunchRevit>
        <DisableFastUpToDateCheck>true</DisableFastUpToDateCheck>
        <EnableRevitTestConfigurations>true</EnableRevitTestConfigurations>
        <ProduceReferenceAssembly>true</ProduceReferenceAssembly>
        <DeployAddin
                Condition="$([System.String]::Copy('$(Configuration)').Contains('.Tests')) == 'True'"
        >false
        </DeployAddin>
        <LaunchRevit
                Condition="$([System.String]::Copy('$(Configuration)').Contains('.Tests')) == 'True'"
        >false
        </LaunchRevit>
        <EnableDynamicLoading>true</EnableDynamicLoading>
    </PropertyGroup>
    <PropertyGroup Condition="'$(Configuration)' != '' and $(Configuration.Contains('Release'))">
        <IsRepackable>true</IsRepackable>
    </PropertyGroup>
    <ItemGroup>
        <!-- Revit Platform -->
        <PackageReference Include="JetBrains.Annotations" Version="2025.2.4"/>
        <PackageReference Include="Nice3point.Revit.Toolkit" Version="$(RevitVersion).*"/>
        <PackageReference Include="Nice3point.Revit.Extensions" Version="$(RevitVersion).*"/>
        <PackageReference Include="Nice3point.Revit.Api.RevitAPI" Version="$(RevitVersion).*"/>
        <PackageReference Include="Nice3point.Revit.Api.RevitAPIUI" Version="$(RevitVersion).*"/>
        <PackageReference Include="RevitExplorer.API" Version="2.6.0"/>
        <PackageReference Include="ricaun.Revit.UI.Tasks" Version="1.*"/>
        <!-- Build -->
        <PackageReference Include="ILRepack" Version="2.0.44">
            <IncludeAssets
            >runtime; build; native; contentfiles; analyzers; buildtransitive
            </IncludeAssets>
            <PrivateAssets>all</PrivateAssets>
            <IncludeAssets
            >runtime; build; native; contentfiles; analyzers; buildtransitive
            </IncludeAssets>
            <PrivateAssets>all</PrivateAssets>
        </PackageReference>
    </ItemGroup>
    <ItemGroup>
        <Resource Include="Resources\Icons\RibbonIcon16.png"/>
        <Resource Include="Resources\Icons\RibbonIcon32.png"/>
        <Resource Include="Resources\id-card16.png"/>
        <Resource Include="Resources\id-card32.png"/>
        <Resource Include="Resources\key-round16.png"/>
        <Resource Include="Resources\key-round32.png"/>
        <Resource Include="Resources\key-square16.png"/>
        <Resource Include="Resources\key-square32.png"/>
        <Resource Include="Resources\monitor-down16.png"/>
        <Resource Include="Resources\monitor-down32.png"/>
        <Resource Include="Resources\Red_16.png"/>
        <Resource Include="Resources\Red_32.png"/>
        <Resource Include="Resources\square-terminal16.png"/>
        <Resource Include="Resources\square-terminal32.png"/>
    </ItemGroup>
    <ItemGroup>
        <None
                Include="..\Pe.Revit.Tests\Fixtures\Profiles\**\*.json"
                Link="Benchmarks\Profiles\%(RecursiveDir)%(Filename)%(Extension)"
                CopyToOutputDirectory="PreserveNewest"
        />
    </ItemGroup>
    <ItemGroup>
        <ProjectReference Include="..\Pe.Revit.FamilyFoundry\Pe.Revit.FamilyFoundry.csproj"/>
        <ProjectReference Include="..\Pe.Revit\Pe.Revit.csproj"/>
        <ProjectReference Include="..\Pe.Revit.Global\Pe.Revit.Global.csproj"/>
        <ProjectReference Include="..\Pe.Revit.SettingsRuntime\Pe.Revit.SettingsRuntime.csproj"/>
        <ProjectReference Include="..\Pe.Revit.Scripting\Pe.Revit.Scripting.csproj"/>
        <ProjectReference Include="..\Pe.Shared.HostContracts\Pe.Shared.HostContracts.csproj"/>
        <ProjectReference Include="..\Pe.Revit.Ui\Pe.Revit.Ui.csproj"/>
    </ItemGroup>
    <ItemGroup>
        <!-- Pe.Host retired: the Revit add-in now launches the TS @pe/host (see TsHostLauncher /
             HostBridgeConnector; repoint to spawn the TS host package, mirroring the
             TS-side ensurePeHostRunning repoint). No Pe.Host code coupling in Pe.App. -->
        <PeInteractiveRuntimeCompanionProject Include="..\Pe.Dev.Cli\Pe.Dev.Cli.csproj"/>
    </ItemGroup>
    <Target
            Name="LaunchAddinApprovalWatcher"
            AfterTargets="DeployAddin"
            Condition="'$(DeployAddin)' == 'true' and '$(LaunchRevit)' == 'true' and '$(DesignTimeBuild)' != 'true'"
    >
        <PropertyGroup>
            <PeApprovalWatcherCliPath>$(PeStableCliPath)</PeApprovalWatcherCliPath>
        </PropertyGroup>
        <Message
                Text="Launching approval watcher via '$(PeApprovalWatcherCliPath)' for Revit $(RevitVersion)."
                Importance="High"
                Condition="Exists('$(PeApprovalWatcherCliPath)')"
        />
        <Warning
                Text="Skipping approval watcher because pe-dev was not found at '$(PeApprovalWatcherCliPath)'. Build source/Pe.Dev.Cli with configuration '$(PeStableCliConfiguration)' to restore the hook."
                Condition="!Exists('$(PeApprovalWatcherCliPath)')"
        />
        <Exec
                Command="dotnet exec &quot;$(PeApprovalWatcherCliPath)&quot; --repo-root &quot;$(MSBuildProjectDirectory)\..\..&quot; __internal approve-worker --revit-year $(RevitVersion)"
                Condition="Exists('$(PeApprovalWatcherCliPath)')"
        />
    </Target>
    <Target
            Name="WritePeAppRuntimeDescriptor"
            AfterTargets="PublishAddin"
            Condition="'$(PublishAddin)' == 'true' and '$(DesignTimeBuild)' != 'true'"
    >
        <PropertyGroup>
            <PeAppRuntimeDescriptorPublishPath>$(AddinPublishDir)\$(AssemblyName)\$(PeRevitRuntimeDescriptorFileName)</PeAppRuntimeDescriptorPublishPath>
            <_PeRuntimeDescriptorLaneJson>$([System.String]::Copy('$(PeRuntimeLane)').Replace('\', '/'))</_PeRuntimeDescriptorLaneJson>
            <_PeRuntimeDescriptorConfigurationJson>$([System.String]::Copy('$(Configuration)').Replace('\', '/'))</_PeRuntimeDescriptorConfigurationJson>
        </PropertyGroup>
        <MakeDir Directories="$(AddinPublishDir)\$(AssemblyName)"/>
        <ItemGroup>
            <PeAppRuntimeDescriptorLines Include="{" />
            <PeAppRuntimeDescriptorLines Include="  &quot;schemaVersion&quot;: 1," />
            <PeAppRuntimeDescriptorLines Include="  &quot;productName&quot;: &quot;$(PeProductName)&quot;," />
            <PeAppRuntimeDescriptorLines Include="  &quot;runtimeLane&quot;: &quot;$(_PeRuntimeDescriptorLaneJson)&quot;," />
            <PeAppRuntimeDescriptorLines Include="  &quot;configuration&quot;: &quot;$(_PeRuntimeDescriptorConfigurationJson)&quot;" />
            <PeAppRuntimeDescriptorLines Include="}" />
        </ItemGroup>
        <WriteLinesToFile
                File="$(PeAppRuntimeDescriptorPublishPath)"
                Lines="@(PeAppRuntimeDescriptorLines)"
                Overwrite="true"
        />
        <Message
                Text="Wrote Pe.App runtime descriptor '$(PeAppRuntimeDescriptorPublishPath)' with lane $(PeRuntimeLane)."
                Importance="High"
        />
    </Target>
    <Target
            Name="CleanAddinPublishAndDeployDirectories"
            BeforeTargets="PublishAddin"
            Condition="'$(PublishAddin)' == 'true'"
    >
        <!-- DeployAddin copies staged package output into the live Revit add-ins folder. Keep live deploy cleanup explicit. -->
        <RemoveDir
                Directories="$(AddinDeployDir)\$(AssemblyName)"
                Condition="'$(DeployAddin)' == 'true' and Exists('$(AddinDeployDir)\$(AssemblyName)')"
        />
        <Delete
                Files="$(AddinDeployDir)\$(AssemblyName).addin"
                Condition="'$(DeployAddin)' == 'true' and Exists('$(AddinDeployDir)\$(AssemblyName).addin')"
        />
    </Target>
</Project>
