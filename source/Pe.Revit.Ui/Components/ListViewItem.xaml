<Border x:Class="Pe.Revit.Ui.Components.ListViewItem"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:local="clr-namespace:Pe.Revit.Ui.Components"
        Background="Transparent">
    <Grid x:Name="ContentGrid">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <Border x:Name="ColorIndicator"
                Grid.Column="0"
                Width="6"
                MinHeight="20"
                CornerRadius="3,0,0,3"
                Margin="0,4,12,4"
                Visibility="Collapsed" />

        <!-- Fixed-size icon slot: every row gets either its icon or a monogram tile,
             so text always aligns regardless of icon availability -->
        <Grid x:Name="IconSlot"
              Grid.Column="1"
              Width="20"
              Height="20"
              Margin="0,0,10,0"
              VerticalAlignment="Center">
            <Border x:Name="IconFallback"
                    CornerRadius="5"
                    Background="{ui:ThemeResource ControlFillColorDefaultBrush}"
                    BorderThickness="1"
                    BorderBrush="{ui:ThemeResource ControlStrokeColorDefaultBrush}"
                    Visibility="Collapsed">
                <TextBlock x:Name="IconFallbackText"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontSize="10"
                           FontWeight="SemiBold"
                           Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}" />
            </Border>
            <Image x:Name="IconImage"
                   RenderOptions.BitmapScalingMode="HighQuality" />
        </Grid>

        <Grid x:Name="TextGrid"
              Grid.Column="2"
              VerticalAlignment="Center">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <ui:TextBlock x:Name="PrimaryText"
                          Grid.Row="0"
                          FontWeight="Normal"
                          TextTrimming="CharacterEllipsis"
                          Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}" />

            <ui:TextBlock x:Name="SecondaryText"
                          Grid.Row="1"
                          FontSize="10"
                          TextTrimming="CharacterEllipsis"
                          Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}" />
        </Grid>

        <local:Pill x:Name="PillBorder"
                    Grid.Column="3"
                    Background="{ui:ThemeResource ControlAltFillColorTertiaryBrush}"
                    BorderBrush="{ui:ThemeResource ControlStrokeColorDefaultBrush}"
                    Opacity="0.7" />
    </Grid>
</Border>