<core:RevitHostedUserControl x:Class="Pe.Revit.Ui.Components.Palette"
                             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                             xmlns:local="clr-namespace:Pe.Revit.Ui.Components"
                             xmlns:controls="clr-namespace:Pe.Revit.Ui.Controls"
                             xmlns:core="clr-namespace:Pe.Revit.Ui.Core"
                             VerticalAlignment="Top">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Inherit WpfUiResources which includes TextBox styles -->
                <ResourceDictionary Source="pack://application:,,,/Pe.Revit.Ui;component/Core/WpfUiResources.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    <!-- Single window surface: palette + optional detail panel, divided by a hairline -->
    <Border x:Name="RootBackground"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Top"
            CornerRadius="10"
            ClipToBounds="True"
            BorderThickness="1"
            BorderBrush="{ui:ThemeResource ControlStrokeColorDefaultBrush}"
            Background="{ui:ThemeResource ApplicationBackgroundBrush}">
        <Border.Effect>
            <DropShadowEffect Color="Black" Direction="270" ShadowDepth="6" BlurRadius="28" Opacity="0.45" />
        </Border.Effect>
    <Grid x:Name="RootGrid"
          HorizontalAlignment="Stretch"
          VerticalAlignment="Top">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition x:Name="SidebarColumn" Width="0" />
        </Grid.ColumnDefinitions>

        <!-- PALETTE SIDE (chromeless; window chrome lives on RootBackground) -->
        <Border x:Name="PaletteBackground"
                Grid.Column="0"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                Background="Transparent">

            <!-- Main palette content -->
            <Grid x:Name="PaletteContentGrid"
                  HorizontalAlignment="Stretch"
                  VerticalAlignment="Stretch">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <!-- List row is star so it absorbs extra height: when the details panel makes
                         the window taller than the list, the status bar (row 4) stays pinned bottom -->
                    <RowDefinition Height="*" />
                    <!-- Docked mode: PanelBackground is re-parented into this row (bottom details) -->
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Search Box (hero row) with Filter and Pin -->
                <Border x:Name="SearchBoxBorder"
                        Grid.Row="1"
                        ClipToBounds="True"
                        Background="Transparent">
                    <Grid x:Name="SearchBoxGrid"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <ui:TextBox x:Name="SearchTextBox"
                                    Grid.Column="0"
                                    Style="{StaticResource TransparentTextBoxStyle}"
                                    FontSize="16"
                                    PlaceholderText="Search…"
                                    Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                            <ui:TextBox.InputBindings>
                                <KeyBinding Key="Down" Command="{Binding MoveSelectionDownCommand}" />
                                <KeyBinding Key="Up" Command="{Binding MoveSelectionUpCommand}" />
                            </ui:TextBox.InputBindings>
                        </ui:TextBox>

                        <!-- FilterBox will be added programmatically to Grid.Column="1" -->

                        <ui:Button x:Name="DockButton"
                                   Grid.Column="2"
                                   Padding="4"
                                   Margin="8,0,0,0"
                                   VerticalAlignment="Center"
                                   Appearance="Transparent"
                                   BorderThickness="0"
                                   ToolTip="Dock as panel"
                                   Cursor="Hand">
                            <ui:SymbolIcon x:Name="DockIcon"
                                           Symbol="ArrowDownload24"
                                           FontSize="16"
                                           Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}" />
                        </ui:Button>

                        <ui:Button x:Name="PinButton"
                                   Grid.Column="3"
                                   Padding="4"
                                   Margin="4,0,0,0"
                                   VerticalAlignment="Center"
                                   Appearance="Transparent"
                                   BorderThickness="0"
                                   ToolTip="Pin window (keep open when clicking outside)"
                                   Cursor="Hand">
                            <ui:SymbolIcon x:Name="PinIcon"
                                           Symbol="Pin24"
                                           FontSize="16"
                                           Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}" />
                        </ui:Button>
                    </Grid>
                </Border>

                <!-- Top bar: palette-switcher breadcrumb (left) + tab pill. Always visible. -->
                <Grid x:Name="TopBar"
                      Grid.Row="0"
                      Margin="12,10,12,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Switcher trigger: current palette name + chevron (Ctrl+P). Opens the overlay. -->
                    <ui:Button x:Name="SwitcherTriggerButton"
                               Grid.Column="0"
                               Padding="8,3,7,3"
                               VerticalAlignment="Center"
                               Appearance="Secondary"
                               BorderThickness="0"
                               Visibility="Collapsed"
                               ToolTip="Switch palette (Ctrl+P)"
                               Cursor="Hand">
                        <StackPanel Orientation="Horizontal">
                            <ui:TextBlock x:Name="SwitcherTriggerText"
                                          Text="Palette"
                                          FontSize="12"
                                          FontWeight="SemiBold"
                                          VerticalAlignment="Center"
                                          Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}" />
                            <ui:SymbolIcon Symbol="ChevronDown20"
                                           FontSize="11"
                                           Margin="6,1,0,0"
                                           VerticalAlignment="Center"
                                           Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}" />
                        </StackPanel>
                    </ui:Button>

                    <!-- Tab Bar (segmented pill, hidden when no tabs) -->
                    <Border x:Name="TabBarBorder"
                            Grid.Column="1"
                            Visibility="Collapsed"
                            Margin="8,0,0,0"
                            Padding="3"
                            Background="{ui:ThemeResource CardBackgroundFillColorSecondaryBrush}"
                            CornerRadius="6"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center">
                        <controls:AnimatedScrollViewer x:Name="TabScrollViewer"
                                                       HorizontalScrollBarVisibility="Hidden"
                                                       VerticalScrollBarVisibility="Disabled"
                                                       VerticalAlignment="Center">
                            <ItemsControl x:Name="TabBarItemsControl">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>
                        </controls:AnimatedScrollViewer>
                    </Border>
                </Grid>

                <!-- Item List - MaxHeight set dynamically in code based on DefaultVisibleItems.
                     Top-aligned so the list hugs the top of its star row (slack falls below it). -->
                <Border Grid.Row="2"
                        VerticalAlignment="Top"
                        Padding="4,4,4,4">
                    <local:ListView x:Name="ItemListView"
                                    ItemsSource="{Binding FilteredItems}"
                                    SelectedItem="{Binding SelectedItem}"
                                    SelectedIndex="{Binding SelectedIndex}" />
                </Border>

                <!-- Status Bar / Footer: item count (left) + shortcut hints (right). -->
                <Border x:Name="StatusBarBorder"
                        Grid.Row="4"
                        Background="{ui:ThemeResource CardBackgroundFillColorSecondaryBrush}">
                    <Grid x:Name="StatusBarGrid">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <ui:TextBlock x:Name="ItemCountText"
                                      Grid.Column="0"
                                      Text="{Binding FilteredItems.Count, StringFormat=\{0\} items}"
                                      VerticalAlignment="Center"
                                      FontSize="11"
                                      Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}" />

                        <!-- TextTrimming: right-aligned text in a star column overflows LEFT over
                             the item count when the palette is narrow; trimming clips it instead -->
                        <ui:TextBlock x:Name="HelpText"
                                      Grid.Column="1"
                                      Text="↑↓ Navigate · ← Tooltip · → Actions · ↵ Run · Esc Close"
                                      VerticalAlignment="Center"
                                      HorizontalAlignment="Right"
                                      TextTrimming="CharacterEllipsis"
                                      Margin="12,0,0,0"
                                      FontSize="11"
                                      Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}" />

                        <!-- Tab switching hint (only visible when tabs exist) -->
                        <ui:TextBlock x:Name="TabSwitchHint"
                                      Grid.Column="2"
                                      Text="· Ctrl+← → Tabs"
                                      VerticalAlignment="Center"
                                      HorizontalAlignment="Right"
                                      Margin="4,0,0,0"
                                      FontSize="11"
                                      Visibility="Collapsed"
                                      Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}" />

                        <!-- Tray Toggle Button -->
                        <ui:Button x:Name="TrayToggleButton"
                                   Grid.Column="3"
                                   Padding="4"
                                   Margin="4,0,0,0"
                                   Appearance="Secondary"
                                   BorderThickness="0"
                                   Visibility="Collapsed"
                                   ToolTip="Show/Hide Options">
                            <ui:SymbolIcon x:Name="TrayToggleIcon" Symbol="ChevronDown20" FontSize="12" />
                        </ui:Button>
                    </Grid>
                </Border>

                <!-- Pull-Down Tray (collapsible) -->
                <Border x:Name="TrayBorder"
                        Grid.Row="5"
                        Background="{ui:ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderThickness="0,1,0,0"
                        BorderBrush="{ui:ThemeResource ControlStrokeColorDefaultBrush}"
                        MaxHeight="0"
                        ClipToBounds="True">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Padding="12,8,12,8">
                        <ContentControl x:Name="TrayContent" />
                    </ScrollViewer>
                </Border>

                <!-- Command overlay: full-surface takeover that slides down from the top.
                     Hosts both the palette switcher and the per-item Actions list (rows built in code-behind). -->
                <Grid x:Name="Overlay"
                      Grid.Row="0"
                      Grid.RowSpan="6"
                      Panel.ZIndex="30"
                      Visibility="Collapsed">
                    <Border x:Name="OverlayScrim"
                            Background="{ui:ThemeResource ApplicationBackgroundBrush}"
                            Opacity="0.72"
                            MouseLeftButtonDown="OverlayScrim_MouseLeftButtonDown" />

                    <!-- Opaque base (app bg) with a card tint on top so list content never bleeds through. -->
                    <Border x:Name="OverlayPanel"
                            VerticalAlignment="Top"
                            Margin="8"
                            Background="{ui:ThemeResource ApplicationBackgroundBrush}"
                            BorderThickness="1"
                            BorderBrush="{ui:ThemeResource ControlStrokeColorDefaultBrush}"
                            CornerRadius="10">
                        <Border.Effect>
                            <DropShadowEffect Color="Black" Direction="270" ShadowDepth="4" BlurRadius="22" Opacity="0.4" />
                        </Border.Effect>
                        <Border Background="{ui:ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="10">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <ui:TextBlock x:Name="OverlayHeader"
                                              Grid.Row="0"
                                              Text="Switch Palette"
                                              FontSize="10"
                                              FontWeight="SemiBold"
                                              Margin="16,12,16,2"
                                              Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}" />

                                <ScrollViewer x:Name="OverlayScroll"
                                              Grid.Row="1"
                                              MaxHeight="392"
                                              VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled"
                                              Padding="8,4,8,8">
                                    <StackPanel x:Name="OverlayList" />
                                </ScrollViewer>
                            </Grid>
                        </Border>
                    </Border>
                </Grid>
            </Grid>
        </Border>

        <!-- PANEL SIDE: same surface, hairline divider (initially collapsed) -->
        <!-- MaxHeight set dynamically in code to match palette height -->
        <Border x:Name="PanelBackground"
                Grid.Column="1"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                BorderThickness="1,0,0,0"
                BorderBrush="{ui:ThemeResource ControlStrokeColorDefaultBrush}"
                Background="Transparent">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Panel Header with expand button -->
                <Border Grid.Row="0"
                        Padding="12,8,8,4"
                        BorderThickness="0,0,0,1"
                        BorderBrush="{ui:ThemeResource ControlStrokeColorDefaultBrush}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <ui:TextBlock x:Name="PanelTitle"
                                      Grid.Column="0"
                                      Text="Details"
                                      VerticalAlignment="Center"
                                      FontSize="12"
                                      FontWeight="SemiBold"
                                      Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}" />

                        <ui:Button x:Name="ExpandPanelButton"
                                   Grid.Column="1"
                                   Padding="4"
                                   Appearance="Secondary"
                                   BorderThickness="0"
                                   ToolTip="Expand panel">
                            <ui:SymbolIcon Symbol="ArrowMaximize20" FontSize="14" />
                        </ui:Button>
                    </Grid>
                </Border>

                <!-- Panel Content - FontSize 13 for better readability of table data -->
                <ScrollViewer x:Name="PanelScrollViewer"
                              Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Padding="12,8,12,12"
                              FontSize="13">
                    <ContentControl x:Name="SidebarContent" />
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
    </Border>
</core:RevitHostedUserControl>