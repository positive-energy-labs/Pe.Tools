{
  "name": "pe-tools",
  "version": "0.0.0",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*",
      "tools/*"
    ],
    "catalog": {
      "@types/node": "^24",
      "typescript": "^5",
      "vite": "npm:@voidzero-dev/vite-plus-core@0.2.1",
      "vite-plus": "0.2.1"
    }
  },
  "type": "module",
  "scripts": {
    "ready": "vp check && vp run -r test -- --passWithNoTests && vp run -r build",
    "test": "vp run -r test -- --passWithNoTests",
    "dev:pea-web": "pe-dev web pea",
    "dev:peco-web": "pe-dev web peco"
  },
  "devDependencies": {
    "jiti": "^2.7.0",
    "vite-plus": "catalog:"
  },
  "overrides": {
    "vite": "catalog:"
  },
  "engines": {
    "node": ">=22.19.0"
  },
  "packageManager": "pnpm@11.5.2"
}
