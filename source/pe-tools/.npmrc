; ponytail: stop pnpm re-running `install` before every dev script. The preview harness
; invokes a newer global pnpm (11.9.0) than packageManager (11.5.2); its deps-status check
; against this lockfile aborts with ERR_PNPM_ABORTED_REMOVE_MODULES_DIR_NO_TTY. Remove if the
; harness pnpm ever matches packageManager.
verify-deps-before-run=false
confirm-modules-purge=false
