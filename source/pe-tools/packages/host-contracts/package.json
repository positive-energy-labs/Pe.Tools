{
  "name": "@pe/host-contracts",
  "version": "0.0.0",
  "description": "Generated Pe host Effect schemas and RPC contracts.",
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    "./contracts": {
      "types": "./src/contracts/index.ts",
      "import": "./src/contracts/index.ts",
      "default": "./src/contracts/index.ts"
    },
    "./operation-types": {
      "types": "./src/operation-types.ts",
      "import": "./src/operation-types.ts",
      "default": "./src/operation-types.ts"
    },
    "./generated": {
      "types": "./src/generated/host-ops.generated.ts",
      "import": "./src/generated/host-ops.generated.ts",
      "default": "./src/generated/host-ops.generated.ts"
    },
    "./service-identity": {
      "types": "./src/service-identity.ts",
      "import": "./src/service-identity.ts",
      "default": "./src/service-identity.ts"
    },
    "./pe-service": {
      "types": "./src/vendor/pe-service.ts",
      "import": "./src/vendor/pe-service.ts",
      "default": "./src/vendor/pe-service.ts"
    },
    "./pe-service-host": {
      "types": "./src/vendor/pe-service-host.ts",
      "import": "./src/vendor/pe-service-host.ts",
      "default": "./src/vendor/pe-service-host.ts"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "test": "vp test",
    "check": "vp check",
    "prepublishOnly": "vp run build",
    "codegen": "vpx node --import jiti/register scripts/host-typegen.ts",
    "codegen:check": "vpx node --import jiti/register scripts/host-typegen.ts --check"
  },
  "dependencies": {
    "effect": "4.0.0-beta.92"
  },
  "devDependencies": {
    "@types/node": "^25.6.2",
    "@typescript/native-preview": "7.0.0-dev.20260509.2",
    "bumpp": "^11.1.0",
    "json-schema-to-typescript": "catalog:",
    "typescript": "^6.0.3",
    "vite-plus": "catalog:"
  }
}
