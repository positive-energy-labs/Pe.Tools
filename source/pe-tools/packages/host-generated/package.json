{
  "name": "@pe/host-generated",
  "version": "0.0.0",
  "description": "Generated Pe host TypeScript contracts and DTO types.",
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/contracts/index.ts",
      "import": "./src/contracts/index.ts"
    },
    "./contracts": {
      "types": "./src/contracts/index.ts",
      "import": "./src/contracts/index.ts"
    },
    "./types": {
      "types": "./src/types/index.ts",
      "import": "./src/types/index.ts"
    },
    "./types/*": {
      "types": "./src/types/*.ts",
      "import": "./src/types/*.ts"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "test": "vp test",
    "check": "vp check",
    "prepublishOnly": "vp run build"
  },
  "devDependencies": {
    "@types/node": "^25.6.2",
    "@typescript/native-preview": "7.0.0-dev.20260509.2",
    "bumpp": "^11.1.0",
    "typescript": "^6.0.3",
    "vite-plus": "catalog:"
  }
}
