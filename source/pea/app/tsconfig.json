{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "types": ["node"],
  },
  "include": [
    "*.ts",
    "bundled-skill-content/**/*.ts",
    "dev-agent-skill-content/**/*.ts",
    "generated/*.ts",
    "generated/host-types/**/*.ts",
    "tools/**/*.ts",
  ],
}
