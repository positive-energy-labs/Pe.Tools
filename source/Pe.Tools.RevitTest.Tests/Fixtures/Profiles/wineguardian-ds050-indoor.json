        "Dir": "out"
      },
      "Drain Side": { "From": "@CenterFB", "By": "param:DrainSideOffset", "Dir": "out" },
      "Drain Elevation": { "From": "@Bottom", "By": "param:DrainElevation", "Dir": "out" }
    },
    "Spans": [],
    "Prisms": [
      {
        "Name": "Cabinet",
        "IsSolid": true,
        "On": "@Bottom",
        "Width": {
          "About": "@CenterFB",
          "By": "param:PE_G_Dim_Width1",
          "Negative": "Cabinet Back",
          "Positive": "Cabinet Front"
        },
        "Length": {
          "About": "@CenterLR",
          "By": "param:PE_G_Dim_Length1",
          "Negative": "Cabinet Left",
          "Positive": "Cabinet Right"
        },
        "Height": {
          "Name": "Cabinet Top",
          "From": "@Bottom",
          "By": "param:PE_G_Dim_Height1",
          "Dir": "out"
        }
      }
    ],
    "Cylinders": [],
    "Connectors": [
      {
        "Name": "SupplyAir",
        "Domain": "Duct",
        "Face": "plane:Cabinet Top",
        "Depth": { "By": "param:SupplyAirDepth", "Dir": "out" },
        "Round": {
          "Center": ["@CenterLR", "@CenterFB"],
          "Diameter": { "By": "param:SupplyAirDiameter" }
        },
        "Config": {
          "SystemType": "SupplyAir",
          "FlowConfiguration": "Preset",
          "FlowDirection": "Out",
          "LossMethod": "NotDefined"
        }
      },
      {
        "Name": "ReturnAir",
        "Domain": "Duct",
        "Face": "plane:Cabinet Back",
        "Depth": { "By": "param:ReturnAirDepth", "Dir": "in" },
        "Round": {
          "Center": ["@CenterLR", "plane:Return Air Elevation"],
          "Diameter": { "By": "param:ReturnAirDiameter" }
        },
        "Config": {
          "SystemType": "ReturnAir",
          "FlowConfiguration": "Preset",
          "FlowDirection": "In",
          "LossMethod": "NotDefined"
        }
      },
      {
        "Name": "LiquidLine",
        "Domain": "Pipe",
        "Face": "plane:Cabinet Left",
        "Depth": { "By": "param:RefrigerantDepth", "Dir": "in" },
        "Round": {
          "Center": [
            "plane:Liquid Line Center",
            "plane:Service Line Elevation"
          ],
          "Diameter": {
            "By": "param:LiquidLineDiameter"
          }
        },
        "Config": {
          "SystemType": "OtherPipe",
          "FlowDirection": "In"
        }
      },
      {
        "Name": "SuctionLine",
        "Domain": "Pipe",
        "Face": "plane:Cabinet Left",
        "Depth": { "By": "param:RefrigerantDepth", "Dir": "in" },
        "Round": {
          "Center": [
            "plane:Suction Line Center",
            "plane:Service Line Elevation"
          ],
          "Diameter": {
            "By": "param:SuctionLineDiameter"
          }
        },
        "Config": {
          "SystemType": "OtherPipe",
          "FlowDirection": "Out"
        }
      },
      {
        "Name": "CondensateDrain",
        "Domain": "Pipe",
        "Face": "plane:Cabinet Left",
        "Depth": { "By": "param:DrainDepth", "Dir": "in" },
        "Round": {
          "Center": ["plane:Drain Side", "plane:Drain Elevation"],
          "Diameter": {
            "By": "param:DrainDiameter"
          }
        },
        "Config": {
          "SystemType": "Sanitary",
          "FlowDirection": "Out"
        }
      }
    ]
