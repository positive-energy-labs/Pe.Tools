<Project Sdk="Microsoft.NET.Sdk">
    <PropertyGroup>
        <TargetFramework>net8.0-windows</TargetFramework>
        <Nullable>enable</Nullable>
        <ImplicitUsings>enable</ImplicitUsings>
        <IsTestProject>true</IsTestProject>
        <EnableRevitTestConfigurations>true</EnableRevitTestConfigurations>
    </PropertyGroup>

    <ItemGroup>
        <PackageReference Include="Microsoft.NET.Test.Sdk" Version="17.14.1"/>
        <PackageReference Include="NUnit" Version="3.13.3"/>
        <PackageReference Include="ricaun.RevitTest.TestAdapter" Version="1.11.0"/>
        <PackageReference Include="Nice3point.Revit.Api.RevitAPI" Version="$(RevitVersion).*"/>
        <PackageReference Include="Nice3point.Revit.Api.RevitAPIUI" Version="$(RevitVersion).*"/>
    </ItemGroup>

    <ItemGroup>
        <ProjectReference Include="..\Pe.App\Pe.App.csproj"/>
        <ProjectReference Include="..\Pe.Host\Pe.Host.csproj" />
        <ProjectReference Include="..\Pe.Revit.FamilyFoundry\Pe.Revit.FamilyFoundry.csproj" />
        <ProjectReference Include="..\Pe.Revit.Global\Pe.Revit.Global.csproj" />
        <ProjectReference Include="..\Pe.Revit.Scripting\Pe.Revit.Scripting.csproj" />
        <ProjectReference Include="..\Pe.Scripting.Cli\Pe.Scripting.Cli.csproj" />
        <ProjectReference Include="..\Pe.Shared.SettingsCatalog\Pe.Shared.SettingsCatalog.csproj" />
    </ItemGroup>

    <ItemGroup>
        <None Include="Fixtures\Profiles\**\*.json" CopyToOutputDirectory="PreserveNewest"/>
        <None Include="Fixtures\Families\**\*.rfa" CopyToOutputDirectory="PreserveNewest"/>
    </ItemGroup>

    <ItemGroup>
        <AssemblyAttribute Include="System.Reflection.AssemblyMetadataAttribute">
            <_Parameter1>NUnit.Version</_Parameter1>
            <_Parameter2>$(RevitVersion)</_Parameter2>
        </AssemblyAttribute>
        <AssemblyAttribute Include="System.Reflection.AssemblyMetadataAttribute">
            <_Parameter1>NUnit.Language</_Parameter1>
            <_Parameter2>ENU</_Parameter2>
        </AssemblyAttribute>
        <AssemblyAttribute Include="System.Reflection.AssemblyMetadataAttribute">
            <_Parameter1>NUnit.Verbosity</_Parameter1>
            <_Parameter2>1</_Parameter2>
        </AssemblyAttribute>
        <AssemblyAttribute Include="System.Reflection.AssemblyMetadataAttribute">
            <_Parameter1>NUnit.Timeout</_Parameter1>
            <_Parameter2>20</_Parameter2>
        </AssemblyAttribute>
    </ItemGroup>

    <!--
      `.Tests` builds are the safe Revit-backed test lane. This post-build hook
      only helps the live Rider/Revit workflow by preparing/triggering Rider hot
      reload for changed runtime files and auto-approving add-in dialogs. The
      actual runtime code still comes from the addin-loaded assemblies in Revit.
    -->
    <Target Name="PostBuildPrepareRiderHotReload" AfterTargets="Build" Condition="$([System.String]::Copy('$(Configuration)').Contains('.Tests')) == 'True'">
        <Exec Command="powershell.exe -ExecutionPolicy Bypass -NoProfile -File &quot;$(MSBuildProjectDirectory)\PostBuildHotReload.ps1&quot; -ScriptDirectory &quot;$(MSBuildProjectDirectory)&quot; -RevitYear $(RevitVersion)"/>
    </Target>
</Project>
