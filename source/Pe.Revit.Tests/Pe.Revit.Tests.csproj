<Project Sdk="Microsoft.NET.Sdk">
    <PropertyGroup>
        <Nullable>enable</Nullable>
        <ImplicitUsings>enable</ImplicitUsings>
        <IsTestProject>true</IsTestProject>
        <EnableRevitTestConfigurations>true</EnableRevitTestConfigurations>
    </PropertyGroup>

    <ItemGroup>
        <PackageReference Include="Microsoft.NET.Test.Sdk" Version="17.14.1" />
        <PackageReference Include="NUnit" Version="3.13.3" />
        <PackageReference Include="ricaun.RevitTest.TestAdapter" Version="1.11.0" />
        <PackageReference Include="Nice3point.Revit.Api.RevitAPI" Version="$(RevitVersion).*" />
        <PackageReference Include="Nice3point.Revit.Api.RevitAPIUI" Version="$(RevitVersion).*" />
    </ItemGroup>

    <ItemGroup>
        <ProjectReference Include="..\Pe.App\Pe.App.csproj" />
        <ProjectReference Include="..\Pe.Dev.Cli\Pe.Dev.Cli.csproj" />
        <ProjectReference Include="..\Pe.Host\Pe.Host.csproj" />
        <ProjectReference Include="..\Pe.Revit.FamilyFoundry\Pe.Revit.FamilyFoundry.csproj" />
        <ProjectReference Include="..\Pe.Revit\Pe.Revit.csproj" />
        <ProjectReference Include="..\Pe.Revit.Global\Pe.Revit.Global.csproj" />
        <ProjectReference Include="..\Pe.Revit.Scripting\Pe.Revit.Scripting.csproj" />
    </ItemGroup>

    <ItemGroup>
        <None Include="Fixtures\Profiles\**\*.json" CopyToOutputDirectory="PreserveNewest" />
        <None Include="Fixtures\Families\**\*.rfa" CopyToOutputDirectory="PreserveNewest" />
    </ItemGroup>

    <ItemGroup>
        <AssemblyAttribute Include="System.Reflection.AssemblyMetadataAttribute">
            <_Parameter1>NUnit.Version</_Parameter1>
            <_Parameter2>$(RevitVersion)</_Parameter2>
        </AssemblyAttribute>
        <AssemblyAttribute Include="System.Reflection.AssemblyMetadataAttribute">
            <_Parameter1>NUnit.Language</_Parameter1>
            <_Parameter2>ENU</_Parameter2>
        </AssemblyAttribute>
        <AssemblyAttribute Include="System.Reflection.AssemblyMetadataAttribute">
            <_Parameter1>NUnit.Verbosity</_Parameter1>
            <_Parameter2>1</_Parameter2>
        </AssemblyAttribute>
        <AssemblyAttribute Include="System.Reflection.AssemblyMetadataAttribute">
            <_Parameter1>NUnit.Timeout</_Parameter1>
            <_Parameter2>20</_Parameter2>
        </AssemblyAttribute>
    </ItemGroup>

    <PropertyGroup>
        <PeStableCliConfiguration
        >$([System.String]::Copy('$(Configuration)').Replace('.Tests', ''))</PeStableCliConfiguration>
    </PropertyGroup>
    <!--
      TODO: decide whether to run hot-reload before VSTest target.
      `.Tests` outputs are isolated and RRD-safe. This pre-test hook is only a
      best-effort attempt to align the already-running live runtime with the
      just-built source immediately before VSTest executes.
    -->
</Project>
