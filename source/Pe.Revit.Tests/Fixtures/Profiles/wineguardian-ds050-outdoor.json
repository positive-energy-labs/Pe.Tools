{
  "ExecutionOptions": {
    "SingleTransaction": false,
    "OptimizeTypeOperations": false
  },
  "FilterFamilies": {
    "IncludeNames": {
      "Equaling": ["FF-Test-WineGuardianDS050Outdoor.rfa"]
    }
  },
  "ParamDrivenSolids": {
    "Frame": "NonHosted",
    "Planes": {
      "Service Panel Center": {
        "From": "@CenterFB",
        "By": "param:ServicePanelOffset",
        "Dir": "out"
      },
      "Service Line Elevation": {
        "From": "@Bottom",
        "By": "param:ServiceLineElevation",
        "Dir": "out"
      },
      "Liquid Line Center": {
        "From": "@CenterFB",
        "By": "param:LiquidLineCenterOffset",
        "Dir": "out"
      },
      "Suction Line Center": {
        "From": "@CenterFB",
        "By": "param:SuctionLineCenterOffset",
        "Dir": "out"
      }
    },
    "Spans": [],
    "Prisms": [
      {
        "Name": "Cabinet",
        "IsSolid": true,
        "On": "@Bottom",
        "Width": {
          "About": "@CenterFB",
          "By": "param:PE_G_Dim_Width1",
          "Negative": "Cabinet Back",
          "Positive": "Cabinet Front"
        },
        "Length": {
          "About": "@CenterLR",
          "By": "param:PE_G_Dim_Length1",
          "Negative": "Cabinet Left",
          "Positive": "Cabinet Right"
        },
        "Height": {
          "Name": "Cabinet Top",
          "From": "@Bottom",
          "By": "param:PE_G_Dim_Height1",
          "Dir": "out"
        }
      }
    ],
    "Cylinders": [],
    "Connectors": [
      {
        "Name": "LiquidLine",
        "Domain": "Pipe",
        "Face": "plane:Cabinet Left",
        "Depth": {
          "By": "param:ServiceLineDepth",
          "Dir": "in"
        },
        "Round": {
          "Center": ["plane:Liquid Line Center", "plane:Service Line Elevation"],
          "Diameter": {
            "By": "param:LiquidLineDiameter"
          }
        },
        "Config": {
          "SystemType": "OtherPipe",
          "FlowDirection": "Out"
        }
      },
      {
        "Name": "SuctionLine",
        "Domain": "Pipe",
        "Face": "plane:Cabinet Left",
        "Depth": {
          "By": "param:ServiceLineDepth",
          "Dir": "in"
        },
        "Round": {
          "Center": ["plane:Suction Line Center", "plane:Service Line Elevation"],
          "Diameter": {
            "By": "param:SuctionLineDiameter"
          }
        },
        "Config": {
          "SystemType": "OtherPipe",
          "FlowDirection": "In"
        }
      }
    ]
  },
  "SharedParameterSelection": {
    "Include": {
      "Names": ["PE_G_Dim_Height1", "PE_G_Dim_Length1", "PE_G_Dim_Width1"]
    },
    "Exclude": {}
