<Project>
    <PropertyGroup>
        <PeDefaultRevitYear>2025</PeDefaultRevitYear>
        <PeSupportedRevitYears>2023;2024;2025;2026</PeSupportedRevitYears>
        <PeAutomationSupportedRevitYears>2023;2024;2025;2026</PeAutomationSupportedRevitYears>
        <PeDefaultRevitConfiguration>Debug.R25</PeDefaultRevitConfiguration>
        <PeStableCliConfiguration Condition="'$(PeStableCliConfiguration)' == ''">Debug.R25</PeStableCliConfiguration>
        <PeIsolatedBuildsUseArtifacts>true</PeIsolatedBuildsUseArtifacts>

        <PeRepositoryRoot>$([System.IO.Path]::GetFullPath('$(MSBuildThisFileDirectory)..\'))</PeRepositoryRoot>
        <PeArtifactsRoot>$([System.IO.Path]::GetFullPath('$(PeRepositoryRoot).artifacts\'))</PeArtifactsRoot>
        <PePackagesRoot>$([System.IO.Path]::GetFullPath('$(PeArtifactsRoot)packages\'))</PePackagesRoot>
        <PeBuildArtifactsRoot>$([System.IO.Path]::GetFullPath('$(PeArtifactsRoot)build\'))</PeBuildArtifactsRoot>
        <PePublishArtifactsRoot>$([System.IO.Path]::GetFullPath('$(PeArtifactsRoot)publish\'))</PePublishArtifactsRoot>
        <PeToolsArtifactsRoot>$([System.IO.Path]::GetFullPath('$(PeArtifactsRoot)tools\'))</PeToolsArtifactsRoot>
    </PropertyGroup>

    <PropertyGroup>
        <PeRevitDebugConfigurations>Debug.R23;Debug.R24;Debug.R25;Debug.R26</PeRevitDebugConfigurations>
        <PeRevitReleaseConfigurations>Release.R23;Release.R24;Release.R25;Release.R26</PeRevitReleaseConfigurations>
        <PeRevitTestConfigurations>Debug.R23.Tests;Debug.R24.Tests;Debug.R25.Tests;Debug.R26.Tests;Release.R23.Tests;Release.R24.Tests;Release.R25.Tests;Release.R26.Tests</PeRevitTestConfigurations>

        <PeCompileRevitConfigurations>Release.R23;Release.R24;Release.R25;Release.R26</PeCompileRevitConfigurations>
        <PePackConfigurations>Release.R23;Release.R24;Release.R25;Release.R26</PePackConfigurations>
        <PeAutomationPackConfigurations>Release.R23;Release.R24;Release.R25;Release.R26</PeAutomationPackConfigurations>
        <PeSolutionConfigurations>Debug.R23;Debug.R24;Debug.R25;Debug.R26;Release.R23;Release.R24;Release.R25;Release.R26;Debug.R23.Tests;Debug.R24.Tests;Debug.R25.Tests;Debug.R26.Tests;Release.R23.Tests;Release.R24.Tests;Release.R25.Tests;Release.R26.Tests</PeSolutionConfigurations>
    </PropertyGroup>
</Project>
