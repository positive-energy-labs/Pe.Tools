{
  "product": "Pe.Tools",
  "vendor": "Positive Energy",
  "releases": "kaitpw/Pe.Tools",
  "legacy": [
    "app:bin/pea",
    "app:dev",
    "appdata:Autodesk/ApplicationPlugins/PE_Tools.bundle",
    "programdata:Autodesk/ApplicationPlugins/PE_Tools.bundle",
    "addins:*/Pe.App.runtime.json",
    "addins:*/Pe.Revit",
    "addins:*/Pe.Revit.DocumentData",
    "addins:*/Pe.Revit.FamilyFoundry",
    "addins:*/Pe.Revit.Global",
    "addins:*/Pe.Revit.Scripting",
    "addins:*/Pe.Revit.SettingsRuntime",
    "addins:*/Pe.Revit.Ui"
  ],
  "payloads": [
    {
      "type": "VersionedAddin",
      "name": "Pe.App",
      "source": "stage:revit-addins/Pe.App",
      "entry": "Pe.App.AppCore"
    },
    {
      "type": "Exe",
      "name": "host",
      "source": "source/pe-tools/apps/host/dist-installed"
    },
    {
      "type": "Cli",
      "name": "pe-revit"
    },
    {
      "type": "PathShim",
      "name": "pea",
      "dev": "pnpm --dir \"{root}/source/pe-tools\" --filter @pe/pea pea"
    },
    {
      "type": "PathShim",
      "name": "peco",
      "dev": "pnpm --dir \"{root}/source/pe-tools\" --filter @pe/peco peco"
    }
  ]
}
