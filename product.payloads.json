{
  "product": "Pe.Tools",
  "vendor": "Positive Energy",
  "releases": "kaitpw/Pe.Tools",
  "payloads": [
    {
      "type": "VersionedAddin",
      "name": "Pe.App",
      "source": "stage:revit-addins/Pe.App",
      "entry": "Pe.App.AppCore"
    },
    {
      "type": "Exe",
      "name": "host",
      "source": "source/pe-tools/apps/host/dist-installed"
    },
    {
      "type": "Cli",
      "name": "pe-revit"
    },
    {
      "type": "PathShim",
      "name": "pea",
      "dev": "pnpm --dir \"{root}/source/pe-tools\" --filter @pe/pea pea"
    },
    {
      "type": "PathShim",
      "name": "peco",
      "dev": "pnpm --dir \"{root}/source/pe-tools\" --filter @pe/peco peco"
    }
  ]
}
